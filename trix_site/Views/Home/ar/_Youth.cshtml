@model trix_site.Models.ContactViewModel
@{
    ViewData["Title"] = "قادة التغيير";
}

@* ملاحظة: ترجمة عربية أولية (مسودة) — يُنصح بمراجعتها من متحدث أصلي قبل النشر. *@

<section class="youth-hero cream">
    <div class="wrap-text">
        <h1>هناك طفل واحد على الأقل<br><span class="accent">يمكنك أن تغيّر له كل شيء.</span></h1>
        <p class="lead">في كل حيّ أطفال اقتنعوا بأنهم "ليسوا جيدين في الحساب". يمكنك أن تكون أنت من يُريهم أنهم مخطئون — وأن تبني في الوقت نفسه شيئًا خاصًّا بك.</p>
        <div class="hero-cta"><a href="#join" class="btn-primary">تريد أن تقود؟ تحدّث معنا</a></div>
    </div>
</section>

<section>
    <div class="wrap">
        <h2 style="text-align:center;">لماذا يستحقّ الأمر</h2>
        <div class="values">
            <div class="value">
                <div class="v-icon">💚</div>
                <h3>عطاء حقيقي</h3>
                <p>تساعد أطفالًا متعثّرين في مجتمعك على أن يؤمنوا بأنفسهم من جديد. هذا أثر يبقى.</p>
            </div>
            <div class="value">
                <div class="v-icon">🚀</div>
                <h3>ريادة ومسؤولية اقتصادية</h3>
                <p>ترافق طلابًا، تتعلّم تحمّل المسؤولية، وتجرّب قيادة شيء خاص بك — مع مقابل عادل عن عملك.</p>
            </div>
            <div class="value">
                <div class="v-icon">🌱</div>
                <h3>وأنت أيضًا تستفيد</h3>
                <p>مَن يُعلّم — يترسّخ لديه ما يُعلّمه. ولأن هذا عمل حقيقي، يستحقّ عليه مقابلًا عادلًا.</p>
            </div>
        </div>
    </div>
</section>

<section class="cream">
    <div class="wrap-text">
        <h2>كيف تُعلّم الأطفال الحساب دون تأهيل معلّم — حتى لو كنت أنت نفسك تجد صعوبة فيه</h2>
        <p>الأهمّ: <strong>لست بحاجة إلى "تعليم" الحساب أو شرحه.</strong> البرنامج يقوم بكل العمل التربوي — يشرح، يعطي تغذية راجعة، ويتقدّم بإيقاع الطفل.</p>
        <div class="reassure">
            <p>دورك ببساطة أن تجلس إلى جانب الطفل، تشجّعه، وتحتفل معه بكل نجاح. القرب الإنساني الذي تقدّمه أثمن من أي درس.</p>
        </div>
    </div>
</section>

<section>
    <div class="wrap">
        <h2 style="text-align:center;">كيف يعمل الأمر</h2>
        <div class="steps">
            <div class="step">
                <div class="step-num">1</div>
                <h3>نتعارف عبر زوم</h3>
                <p>سأعلّمك كيفية العمل مع البرنامج مع الأطفال الأكثر تعثّرًا.</p>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <h3>تحصل على حساب</h3>
                <p>تحصل على حساب مرشد مجاني في النظام، بلا تكلفة.</p>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <h3>تبدأ المرافقة</h3>
                <p>ترافق طلابًا — كلّ واحد على حدة، بإيقاعه الخاص، كمعلّم خصوصي.</p>
            </div>
            <div class="step">
                <div class="step-num">4</div>
                <h3>ترى النتائج</h3>
                <p>لوحة متابعة كاملة تُظهر لك — وللأهل — بالضبط كيف يتقدّم كل طفل.</p>
            </div>
        </div>
    </div>
</section>

<section class="cream">
    <div class="wrap">
        <div class="educator-note">
            <h3>المعلّمون والمنسّقون وأهل التربية</h3>
            <p>نعلم أن هناك قواعد واضحة بشأن التواصل المباشر مع الطلاب. لذلك لا نطلب منكم التوجّه إلى الشباب — بل فقط أن تُعرّفوا بالبرنامج للأهل وللشباب الذين يُبدون اهتمامًا بالفعل. إن أردتم تشغيل مجموعة في إطاركم، أو نقل المعلومات إلى الأهل بشكل منظّم، يسعدنا تنسيق مكالمة معكم. اختاروا "أنا منسّق/معلّم" في النموذج أدناه.</p>
        </div>
    </div>
</section>

<section class="about">
    <div class="about-inner">
        <img src="~/img/ami-coffee.webp" alt="عمي أريخا" class="about-photo" />
        <div class="about-text">
            <h2>من أنا</h2>
            <p>أنا عمي، معلّم رياضيات منذ عشرات السنين، ومؤسّس 12trix. أرافق شخصيًّا كل من ينضمّ — بما في ذلك مكالمة تعارف عبر زوم قبل البدء.</p>
            <p><strong>للأهل:</strong> أتفهّم القلق من شخص غير معروف. لذلك أنا متاح لأي سؤال، ويمكن دائمًا التحدّث معي مباشرة قبل أن ينضمّ ابنكم أو ابنتكم.</p>
            <div class="signature">— عمي أريخا، مؤسّس 12trix</div>
        </div>
    </div>
</section>

<section id="join">
    <div class="wrap">
        <h2 style="text-align:center;">تريدون الانضمام أو معرفة المزيد؟</h2>
        <p style="text-align:center; max-width:600px; margin:0 auto;">املأوا التفاصيل وسأعود إليكم لتنسيق مكالمة تعارف قصيرة. بلا التزام.</p>

        <form class="contact-form wide" method="post" asp-controller="Ar" asp-action="YouthJoin">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

            @* Honeypot *@
            <div style="position:absolute; left:-9999px; top:-9999px;" aria-hidden="true">
                <label for="Website">Website</label>
                <input type="text" id="Website" asp-for="Website" tabindex="-1" autocomplete="off" />
            </div>

            <input type="hidden" asp-for="Language" value="ar" />

            <div class="form-row">
                <label asp-for="Role">أنا...</label>
                <select asp-for="Role" required>
                    <option value="">اختاروا واحدًا</option>
                    <option value="teen">شاب / شابة يريد أن يقود</option>
                    <option value="parent">أحد والدَي شاب/ة يريد الانضمام</option>
                    <option value="educator">منسّق / معلّم / منظّمة شبابية</option>
                </select>
                <span asp-validation-for="Role" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Name">الاسم الكامل</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Phone">الهاتف</label>
                <input asp-for="Phone" type="tel" />
                <span asp-validation-for="Phone" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Message">شيء تودّون إضافته (اختياري)</label>
                <textarea asp-for="Message"></textarea>
                <span asp-validation-for="Message" class="field-error"></span>
            </div>
            <div class="form-submit">
                <button type="submit" class="btn-primary">أرسلوا — وسأعود إليكم</button>
            </div>
            <div class="form-note">التفاصيل تصل مباشرة إلى عمي، مؤسّس 12trix. لا تُنقل إلى أي جهة أخرى.</div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
