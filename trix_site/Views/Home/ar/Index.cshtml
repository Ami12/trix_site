@{
    ViewData["Title"] = "التسجيل للعائلات";
}

@* ملاحظة: هذه ترجمة عربية أولية (مسودة). يُنصح بمراجعتها من متحدث أصلي قبل النشر. *@

<section class="hero">
    <div class="hero-inner">
        <div class="hero-top">
            <div class="hero-text">
                <h1>ليست مجرد علامة.<br><span class="accent">إنها هوية.</span></h1>
                <p class="trust-line">حصل طفلكم على توصية بنا من معلّم تثقون به. هذا وحده يعني الكثير.</p>
                <p>‏12trix هي بيئة تعلّم ذاتي للحساب، لصفوف الأول حتى السادس، مبنية بالكامل على التجربة – بلا شروحات طويلة، بلا نصوص مملّة. يتعلّم الطفل من خلال اللعب والحركة والاكتشاف، وبإيقاعه الخاص.</p>
                <p><strong>ما نعرفه بيقين:</strong> الأطفال الذين يواجهون صعوبة في الحساب لا يحتاجون إلى شرح إضافي. يحتاجون إلى تجربة ينجحون فيها – ويشعرون بذلك.</p>
            </div>
            <div class="hero-image">
                <img src="~/img/classRoom.webp" alt="أطفال يتعلّمون الحساب بطريقة تجريبية" />
            </div>
        </div>
    </div>

    <div class="trial-wrap">
        <div class="trial-box">
            <div class="gift-label">🎁 الأسبوع الأول – هدية</div>
            <p>لكي تروا ذلك بأنفسكم: الأسبوع الأول مفتوح للجميع، بلا تكلفة.</p>
            <a href="https://app.12trix.com/Accounts/Account/registerFamily" class="btn-primary">ابدأوا أسبوع تجربة مجاني</a>
            <span class="btn-note">بدون بطاقة ائتمان. بدون التزام.</span>
        </div>
    </div>
</section>

<section class="next-section">
    <div class="next-inner">
        <img src="~/img/Desktop-1-4-Photoroom.webp" alt="طفل يتعلّم وينجح في الحساب" />
        <div>
            <h2>ماذا يحدث بعد التسجيل؟</h2>
            <p>خلال دقائق يكون الطفل داخل بيئته الخاصة – دون الحاجة إلى معرفة القراءة، فكل شيء مُعبّر عنه ومشروح بالصوت. وأنتم، كأهل، تحصلون على لوحة متابعة تُظهر لكم بالضبط كيف يتقدّم.</p>
        </div>
    </div>
</section>

<section class="video-section">
    <div class="video-inner">
        <h2>شاهدوا ذلك بأعينكم</h2>
        <div class="video-frame">
            <iframe src="https://www.youtube.com/embed/dTUm6IiaORU?rel=0"
                    title="12trix"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen></iframe>
        </div>
    </div>
</section>

<section class="final-cta">
    <div class="final-inner">
        <h2>مستعدّون للبدء؟</h2>
        <a href="https://app.12trix.com/Accounts/Account/registerFamily" class="btn-primary">ابدأوا الآن</a>
    </div>
</section>
