@model trix_site.Models.ContactViewModel
@{
    ViewData["Title"] = "צור קשר";
}

@* NOTE FOR AMI:
   This view assumes a shared _Layout.cshtml provides <html dir="rtl">, the
   navbar, the footer, and links to the shared site.css. The markup below is
   only the page body. If you are NOT using a layout, copy the <nav>/<footer>
   and <head> from the standalone HTML file 12trix-contact.html. *@

<section class="cream">
    <div class="wrap-text" style="padding-bottom:24px;">
        <h1>נשמח לשמוע מכם</h1>
        <p class="intro">יש לכם שאלה, רעיון, או שאתם רוצים לשמוע איך 12trix יכול לעזור? כתבו לי ואחזור אליכם.</p>
    </div>
</section>

<section>
    <div class="contact-grid">
        <form class="contact-form" method="post" asp-action="Contact">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

            @* Honeypot: hidden from humans, must stay empty *@
            <div style="position:absolute; left:-9999px; top:-9999px;" aria-hidden="true">
                <label for="Website">Website</label>
                <input type="text" id="Website" asp-for="Website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-row">
                <label asp-for="Role">אני...</label>
                <select asp-for="Role" required>
                    <option value="">בחרו אחד</option>
                    <option value="parent">הורה</option>
                    <option value="tutor">מורה פרטי / סטודנט</option>
                    <option value="institution">מרכז למידה / מוסד / ארגון</option>
                    <option value="other">אחר</option>
                </select>
                <span asp-validation-for="Role" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Name">שם מלא</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Phone">טלפון</label>
                <input asp-for="Phone" type="tel" />
                <span asp-validation-for="Phone" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Email">אימייל (לא חובה)</label>
                <input asp-for="Email" type="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Message">איך אפשר לעזור?</label>
                <textarea asp-for="Message"></textarea>
                <span asp-validation-for="Message" class="field-error"></span>
            </div>

            <div class="form-submit">
                <button type="submit" class="btn-primary">שלחו — ואחזור אליכם</button>
            </div>
            <div class="form-note">הפרטים מגיעים ישירות לעמי, מייסד 12trix. לא מועברים לאף גורם אחר.</div>
        </form>

        <aside class="direct">
            <img src="~/img/ami-portrait.webp" alt="עמי אריכא" class="direct-photo" />
            <h2>מעדיפים ישירות?</h2>
            <p>מדברים איתי, לא עם בוט.</p>
            <div class="direct-links">
                <a href="https://wa.link/62uesa" class="link-whatsapp">💬 וואטסאפ</a>
                <a href="tel:054-4684-216" class="link-phone">📞 054-4684-216</a>
                <a href="mailto:support@12trix.com" class="link-email">✉️ support@12trix.com</a>
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
