@{
    ViewData["Title"] = "צור קשר - 12trix";
}

<section class="bg-white min-h-[80vh] py-16 px-4">
    <div class="max-w-4xl mx-auto">

        <!-- כותרת ראשית -->
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">בואו נדבר על הילד שלכם</h1>
            <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
                כדי להבטיח תוצאות אמיתיות כמו בפיילוט, חשוב לי לוודא שיש התאמה מלאה בין הצרכים של הילד לבין השיטה שלנו.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12 items-start">

            <!-- אפשרות 1: תיאום שיחה (Calendly) -->
            <div class="bg-blue-50 p-8 rounded-3xl border border-blue-100 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center mb-6">
                    <div class="bg-blue-600 p-3 rounded-full ml-4">
                        <svg xmlns="http://www.w3.org" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900">תיאום שיחה ביומן</h3>
                </div>
                <p class="text-gray-700 mb-8 leading-relaxed">
                    בחרו את הזמן שנוח לכם לשיחת ייעוץ של 15 דקות. ללא התחייבות, רק בדיקת התאמה.
                </p>
                <a href="https://calendly.com" target="_blank" class="block text-center bg-blue-600 text-white font-bold py-4 rounded-xl hover:bg-blue-700 transition-colors shadow-lg">
                    בחירת מועד לשיחה
                </a>
            </div>

            <!-- אפשרות 2: פנייה ישירה (WhatsApp / Mail) -->
            <div class="bg-green-50 p-8 rounded-3xl border border-green-100 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center mb-6">
                    <div class="bg-green-600 p-3 rounded-full ml-4">
                        <svg xmlns="http://www.w3.org" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900">פנייה מהירה</h3>
                </div>
                <p class="text-gray-700 mb-8 leading-relaxed">
                    יש לכם שאלה דחופה? רוצים לכתוב לי לפני שנתאם? אני זמין בווטסאפ ובמייל.
                </p>
                <div class="space-y-4">
                    <a href="https://wa.link/62uesa" target="_blank" class="flex items-center justify-center gap-3 bg-green-600 text-white font-bold py-4 rounded-xl hover:bg-green-700 transition-colors shadow-lg">
                        <span>שלחו הודעת WhatsApp</span>
                    </a>
                    <a href="mailto:support@12trix.co.il" class="flex items-center justify-center text-gray-600 font-medium hover:text-blue-600 transition-colors">
                        <span>או במייל: support@12trix.co.il</span>
                    </a>
                </div>
            </div>

        </div>
        <div class="flex flex-col items-center text-center">
            <div class="w-32 h-32 md:w-40 md:h-40 overflow-hidden rounded-full border-4 border-gray-100 shadow-sm mx-auto mb-4">
                <img src="~/images/amiram.png"
                     alt="עמי"
                     class="w-full h-full object-cover">
            </div>
            <p class="text-gray-500 italic max-w-xs mx-auto">"אני כאן כדי לעזור לילד שלכם לגלות שהוא מסוגל להרבה יותר."</p>
        </div>

       

    </div>
</section>
