@model trix_site.Models.ContactViewModel
@{
    ViewData["Title"] = "מובילי שינוי";
}

<section class="youth-hero cream">
    <div class="wrap-text">
        <h1>לפחות ילד אחד<br><span class="accent">שאתם יכולים לשנות לו הכול.</span></h1>
        <p class="lead">יש ילדים שרק צריכים מישהו שיאמין בהם. אתם יכולים להיות האנשים האלה — וללוות תלמיד שמשתפר בזכותכם, שבוע אחרי שבוע.</p>
        <div class="hero-cta"><a href="#join" class="btn-primary">רוצים להוביל? דברו איתנו</a></div>
    </div>
</section>

<section>
    <div class="wrap">
        <h2 style="text-align:center;">למה זה שווה את זה</h2>
        <div class="values">
            <div class="value">
                <div class="v-icon">💚</div>
                <h3>נתינה אמיתית</h3>
                <p>אתם עוזרים לילדים מתקשים בקהילה שלכם להאמין בעצמם שוב. זו השפעה שנשארת.</p>
            </div>
            <div class="value">
                <div class="v-icon">🚀</div>
                <h3>יזמות ואחריות כלכלית</h3>
                <p>אתם מלווים תלמיד קבוע, לומדים לקחת אחריות, ורואים אותו משתפר — עם תגמול הוגן על העבודה.</p>
            </div>
            <div class="value">
                <div class="v-icon">🌱</div>
                <h3>גם אתם מרוויחים</h3>
                <p>מי שמלמד — מתחזק בעצמו. ומכיוון שזו עבודה אמיתית, מגיע לכם גם תגמול הוגן.</p>
            </div>
        </div>
    </div>
</section>

<section class="cream">
    <div class="wrap-text">
        <h2>איך מלמדים ילדים חשבון בלי הכשרת מורה — גם אם אתם עצמכם מתקשים</h2>
        <p>הדבר הכי חשוב: <strong>אתם לא צריכים "ללמד" או להסביר חשבון.</strong> האפליקציה עושה את כל העבודה הפדגוגית — היא מסבירה, נותנת משוב ומתקדמת בקצב של הילד.</p>
        <div class="reassure">
            <p>התפקיד שלכם הוא פשוט לשבת לצד הילד, לעודד, ולחגוג איתו כל הצלחה. הקרבה האנושית שאתם נותנים שווה יותר מכל שיעור.</p>
        </div>
    </div>
</section>

<section>
    <div class="wrap">
        <h2 style="text-align:center;">איך זה עובד</h2>
        <div class="steps">
            <div class="step">
                <div class="step-num">1</div>
                <h3>נכיר בזום</h3>
                <p>אלמד אתכם איך לעבוד עם התוכנה עם הילדים שהכי מתקשים.</p>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <h3>מקבלים חשבון</h3>
                <p>אתם מקבלים חשבון חונך חינמי במערכת, בלי עלות.</p>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <h3>מתחילים ללוות</h3>
                <p>אתם מלווים תלמידים — כל אחד בנפרד, בקצב שלו, כמו מורה פרטי.</p>
            </div>
            <div class="step">
                <div class="step-num">4</div>
                <h3>רואים תוצאות</h3>
                <p>דשבורד מלא מראה לכם — ולהורים — בדיוק איך כל ילד מתקדם.</p>
            </div>
        </div>
    </div>
</section>

<section class="cream">
    <div class="wrap-text">
        <h2>"ואם לא אדע מה לעשות?"</h2>
        <p>זו השאלה הכי טבעית — וזה בדיוק למה אתם לא לבד בזה. אני מלווה אתכם אישית לאורך כל הדרך: מתחילים בשיחת היכרות בזום שבה אני מראה לכם בדיוק איך זה עובד, ואני נשאר זמין לכל שאלה שתעלה תוך כדי.</p>
        <div class="reassure">
            <p>אם ילד נתקע, אם משהו לא ברור, אם אתם רוצים טיפ — אתם כותבים לי ואני עונה. לא זורקים אתכם למים.</p>
        </div>
    </div>
</section>

<section>
    <div class="wrap">
        <div class="educator-note">
            <h3>רכזי נוער, מדריכים והנהגות הורים</h3>
            <p>אם אתם עובדים עם בני נוער — בתנועת נוער, מתנ"ס, עמותה קהילתית או הנהגת הורים — ורוצים לחבר אותם להזדמנות הזאת, נשמח לדבר. הכנו גם ערכת שיתוף להורים, שאפשר להעביר הלאה בקלות. בחרו "רכז נוער / מדריך / הנהגת הורים" בטופס למטה.</p>
        </div>
    </div>
</section>

<section class="about">
    <div class="about-inner">
        <img src="~/img/ami-coffee.webp" alt="עמי אריכא" class="about-photo" />
        <div class="about-text">
            <h2>מי אני</h2>
            <p>אני עמי אריכא, מורה למתמטיקה כבר עשרות שנים, ומייסד 12trix. אני מלווה אישית כל מי שמצטרף — כולל שיחת היכרות בזום לפני שמתחילים.</p>
            <p><strong>להורים:</strong> אני מבין את החשש מאדם לא מוכר. לכן אני זמין לכל שאלה, ותמיד אפשר לדבר איתי ישירות לפני שהילד/ה מצטרפים.</p>
            <div class="signature">— עמי אריכא, מייסד 12trix</div>
        </div>
    </div>
</section>

<section id="join">
    <div class="wrap">
        <h2 style="text-align:center;">רוצים להצטרף או לשמוע עוד?</h2>
        <p style="text-align:center; max-width:600px; margin:0 auto;">מלאו את הפרטים ואחזור אליכם לתיאום שיחת היכרות קצרה. בלי התחייבות.</p>

        <form class="contact-form wide" method="post" asp-action="YouthJoin">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

            <div style="position:absolute; left:-9999px; top:-9999px;" aria-hidden="true">
                <label for="Website">Website</label>
                <input type="text" id="Website" asp-for="Website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-row">
                <label asp-for="Role">אני...</label>
                <select asp-for="Role" required>
                    <option value="">בחרו אחד</option>
                    <option value="teen">נער / נערה שרוצה להוביל</option>
                    <option value="parent">הורה של נער/ה שרוצה להצטרף</option>
                    <option value="educator">רכז נוער / מדריך / הנהגת הורים</option>
                </select>
                <span asp-validation-for="Role" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Name">שם מלא</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Phone">טלפון</label>
                <input asp-for="Phone" type="tel" />
                <span asp-validation-for="Phone" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Message">משהו שתרצו להוסיף (לא חובה)</label>
                <textarea asp-for="Message"></textarea>
                <span asp-validation-for="Message" class="field-error"></span>
            </div>
            <div class="form-submit">
                <button type="submit" class="btn-primary">שלחו — ואחזור אליכם</button>
            </div>
            <div class="form-note">הפרטים מגיעים ישירות לעמי, מייסד 12trix. לא מועברים לאף גורם אחר.</div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}