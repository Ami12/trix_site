@model trix_site.Models.ContactViewModel
@{
    ViewData["Title"] = "מובילי שינוי";
}

<section class="youth-hero cream">
    <div class="wrap-text">
        <h1>לפחות ילד אחד<br><span class="accent">שאתה יכול לשנות לו הכול.</span></h1>
        <p class="lead">בכל שכונה יש ילדים שהשתכנעו שהם "לא טובים בחשבון". אתה יכול להיות זה שמראה להם שהם טעו — ולבנות תוך כדי משהו משלך.</p>
        <div class="hero-cta"><a href="#join" class="btn-primary">רוצה להוביל? דבר איתנו</a></div>
    </div>
</section>

<section>
    <div class="wrap">
        <h2 style="text-align:center;">למה זה שווה את זה</h2>
        <div class="values">
            <div class="value">
                <div class="v-icon">💚</div>
                <h3>נתינה אמיתית</h3>
                <p>אתה עוזר לילדים מתקשים בקהילה שלך להאמין בעצמם שוב. זו השפעה שנשארת.</p>
            </div>
            <div class="value">
                <div class="v-icon">🚀</div>
                <h3>יזמות ואחריות כלכלית</h3>
                <p>אתה מלווה תלמידים, לומד לקחת אחריות, ומתנסה בלהוביל משהו משלך — עם תגמול הוגן על העבודה.</p>
            </div>
            <div class="value">
                <div class="v-icon">🌱</div>
                <h3>גם אתה מרוויח</h3>
                <p>מי שמלמד — מתחזק בעצמו. ומכיוון שזו עבודה אמיתית, מגיע לך גם תגמול הוגן.</p>
            </div>
        </div>
    </div>
</section>

<section class="cream">
    <div class="wrap-text">
        <h2>איך ללמד ילדים חשבון בלי הכשרת מורה — גם אם אתה עצמך מתקשה</h2>
        <p>הדבר הכי חשוב: <strong>אתה לא צריך "ללמד" או להסביר חשבון.</strong> האפליקציה עושה את כל העבודה הפדגוגית — היא מסבירה, נותנת משוב ומתקדמת בקצב של הילד.</p>
        <div class="reassure">
            <p>התפקיד שלך הוא פשוט לשבת לצד הילד, לעודד, ולחגוג איתו כל הצלחה. הקרבה האנושית שאתה נותן שווה יותר מכל שיעור.</p>
        </div>
    </div>
</section>

<section>
    <div class="wrap">
        <h2 style="text-align:center;">איך זה עובד</h2>
        <div class="steps">
            <div class="step">
                <div class="step-num">1</div>
                <h3>נכיר בזום</h3>
                <p>אני אלמד אותך איך לעבוד עם התוכנה עם הילדים שהכי מתקשים.</p>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <h3>מקבל חשבון</h3>
                <p>אתה מקבל חשבון חונך חינמי במערכת, בלי עלות.</p>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <h3>מתחיל ללוות</h3>
                <p>אתה מלווה תלמידים — כל אחד בנפרד, בקצב שלו, כמו מורה פרטי.</p>
            </div>
            <div class="step">
                <div class="step-num">4</div>
                <h3>רואה תוצאות</h3>
                <p>דשבורד מלא מראה לך — ולהורים — בדיוק איך כל ילד מתקדם.</p>
            </div>
        </div>
    </div>
</section>

<section class="cream">
    <div class="wrap">
        <div class="educator-note">
            <h3>מורים, רכזים ואנשי חינוך</h3>
            <p>אנחנו יודעים שיש כללים ברורים לגבי פנייה ישירה לתלמידים. לכן איננו מבקשים מכם לפנות לנוער — אלא רק לספר על התוכנית להורים ולנוער שכבר מגלים עניין. אם אתם רוצים להריץ קבוצה במסגרת שלכם, או להעביר את המידע להורים בצורה מסודרת, נשמח לתאם איתכם שיחה. בחרו "אני רכז/מורה" בטופס למטה.</p>
        </div>
    </div>
</section>

<section class="about">
    <div class="about-inner">
        <img src="~/img/ami-coffee.webp" alt="עמי אריכא" class="about-photo" />
        <div class="about-text">
            <h2>מי אני</h2>
            <p>אני עמי, מורה למתמטיקה כבר עשרות שנים, ומייסד 12trix. אני מלווה אישית כל מי שמצטרף — כולל שיחת היכרות בזום לפני שמתחילים.</p>
            <p><strong>להורים:</strong> אני מבין את החשש מאדם לא מוכר. לכן אני זמין לכל שאלה, ותמיד אפשר לדבר איתי ישירות לפני שהילד/ה מצטרפים.</p>
            <div class="signature">— עמי אריכא, מייסד 12trix</div>
        </div>
    </div>
</section>

<section id="join">
    <div class="wrap">
        <h2 style="text-align:center;">רוצים להצטרף או לשמוע עוד?</h2>
        <p style="text-align:center; max-width:600px; margin:0 auto;">מלאו את הפרטים ואחזור אליכם לתיאום שיחת היכרות קצרה. בלי התחייבות.</p>

        <form class="contact-form wide" method="post" asp-action="YouthJoin">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

            @* Honeypot *@
            <div style="position:absolute; left:-9999px; top:-9999px;" aria-hidden="true">
                <label for="Website">Website</label>
                <input type="text" id="Website" asp-for="Website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-row">
                <label asp-for="Role">אני...</label>
                <select asp-for="Role" required>
                    <option value="">בחרו אחד</option>
                    <option value="teen">נער / נערה שרוצה להוביל</option>
                    <option value="parent">הורה של נער/ה שרוצה להצטרף</option>
                    <option value="educator">רכז / מורה / ארגון נוער</option>
                </select>
                <span asp-validation-for="Role" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Name">שם מלא</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Phone">טלפון</label>
                <input asp-for="Phone" type="tel" />
                <span asp-validation-for="Phone" class="field-error"></span>
            </div>
            <div class="form-row">
                <label asp-for="Message">משהו שתרצו להוסיף (לא חובה)</label>
                <textarea asp-for="Message"></textarea>
                <span asp-validation-for="Message" class="field-error"></span>
            </div>
            <div class="form-submit">
                <button type="submit" class="btn-primary">שלחו — ואחזור אליכם</button>
            </div>
            <div class="form-note">הפרטים מגיעים ישירות לעמי, מייסד 12trix. לא מועברים לאף גורם אחר.</div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
