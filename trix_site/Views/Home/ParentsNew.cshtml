@{
    ViewData["Title"] = "להורים – 12trix";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO -->
<section class="hero fade-in" style="background:#fff;">
    <div class="container hero-content">
        <div class="hero-text">
            <h1>אם הילד שלך איבד ביטחון במתמטיקה — זה לא אומר שהוא לא מסוגל.</h1>
            <p class="subtitle">
                אנחנו לא מספקים קביים. אנחנו עוזרים לילד לגלות שהוא יכול — בעצמו.
            </p>
            <p class="subtitle" style="margin-top:12px;color:#27AE60;font-weight:600;">
                שיחת ייעוץ עם עמי אריכא, מייסד 12trix
            </p>
            <div class="cta-container">
