                    <tr style="border-bottom:2px solid #e0e0e0;">
                        <th style="padding:16px;">תוכנית</th>
                        <th style="padding:16px;">פרטים</th>
                        <th style="padding:16px;">הערות</th>
                        <th style="padding:16px;">מחיר</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="background:#fff;">
                        <td style="padding:16px;font-weight:600;">💎 בוטקאמפ – קפיצה אמיתית בחודש אחד</td>
