        <p class="subtitle">לא דפים, לא הרצאות — התנסות אמיתית, בלמידה שגורמת להם לחייך.</p>

        <div class="carousel" dir="ltr">
            <button class="carousel-btn prev" aria-label="הקודם">‹</button>
            <div class="carousel-track" id="appsTrack">
                <div class="carousel-slide">
                    <img src="~/images/apps/app-equation.png" alt="אפליקציית משוואות" loading="lazy">
                </div>
                <div class="carousel-slide">
                    <img src="~/images/apps/app-long-division.webp" alt="אפליקציית חילוק ארוך" loading="lazy">
                </div>
                <div class="carousel-slide">
                    <img src="~/images/apps/app-fractions.png" alt="אפליקציית שברים" loading="lazy">
                </div>
                <div class="carousel-slide">
                    <img src="~/images/apps/app-hundredgrid.png" alt="אפליקציית לוח המאה / לוח הכפל" loading="lazy">
                </div>
                <div class="carousel-slide">
                    <img src="~/images/apps/app-foundations.png" alt="אפליקציית יסודות החשבון" loading="lazy">
