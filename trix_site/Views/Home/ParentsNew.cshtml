<!-- המסר האישי -->
<section class="features fade-in" style="background:#fff;">
    <div class="container">
        <h2 class="features-title">הילד שלך לא צריך עזרה — הוא צריך לגלות שהוא מסוגל.</h2>
        <p style="max-width:720px;margin:0 auto;font-size:1.1rem;line-height:1.8;color:#333;">
            כשאני פוגש ילד שאומר “אני לא טוב בזה”, אני יודע שהבעיה היא לא בחשבון — אלא בתחושת המסוגלות.<br>
            ברגע שהוא חווה הצלחה אחת קטנה, משהו מתעורר בו — וזה הרגע שבו הלמידה באמת מתחילה.
        </p>
        <p style="margin-top:24px;font-weight:600;color:#27AE60;">עמי אריכא – מייסד 12trix</p>
    </div>
</section>

<!-- פורם יצירת קשר -->
<section id="contact" class="fade-in" style="background:#f8fafb;padding:80px 0;">
    <div class="container" style="max-width:640px;background:#fff;border-radius:20px;box-shadow:0 8px 24px rgba(0,0,0,0.08);padding:40px;">
        <h2 style="font-size:1.8rem;margin-bottom:16px;">רוצים לדעת איך אפשר לעזור לילד שלכם להצליח במתמטיקה?</h2>
        <p style="margin-bottom:32px;color:#555;font-size:1.1rem;">
            השאירו פרטים ונחזור אליכם לשיחת ייעוץ עם עמי אריכא, מייסד 12trix.<br>
            נבין יחד מה מתאים לילד שלכם ואיך לבנות תהליך שמחזיר לו את הביטחון.
        </p>

        <form asp-action="ContactSubmit" method="post" class="contact-form">
            <div class="form-group" style="margin-bottom:18px;text-align:right;">
                <label for="parentName">שם ההורה</label>
                <input type="text" id="parentName" name="parentName" class="form-control" required placeholder="שם ההורה" />
            </div>
            <div class="form-group" style="margin-bottom:18px;text-align:right;">
                <label for="phone">טלפון</label>
                <input type="tel" id="phone" name="phone" class="form-control" required placeholder="05X-XXXXXXX" />
            </div>
            <div class="form-group" style="margin-bottom:18px;text-align:right;">
                <label for="childAge">גיל הילד</label>
                <input type="text" id="childAge" name="childAge" class="form-control" required placeholder="לדוגמה: כיתה ד’" />
            </div>

            <button type="submit" class="btn-primary" style="width:100%;max-width:300px;margin-top:16px;">
                📞 לקביעת שיחת ייעוץ
            </button>
        </form>

        <p style="margin-top:28px;font-size:0.9rem;color:#777;line-height:1.6;">
            הפרטים נשלחים ישירות אלינו בלבד.<br>
            נחזור אליכם בהקדם לשיחה רגועה ואישית.
        </p>
        <p style="margin-top:10px;font-size:0.9rem;color:#27AE60;font-weight:500;">
            ⏱ לרוב אנחנו חוזרים תוך פחות מ־24 שעות.
        </p>
    </div>
</section>





<script>
    (function () {
      const track = document.getElementById('appsTrack');
      if (!track) return;
      const prev = track.parentElement.querySelector('.prev');
      const next = track.parentElement.querySelector('.next');

      function updateButtons() {
        const maxScroll = track.scrollWidth - track.clientWidth - 1;
        prev.disabled = track.scrollLeft <= 0;
        next.disabled = track.scrollLeft >= maxScroll;
      }

      function scrollByOne(dir) {
        track.scrollBy({ left: dir * track.clientWidth, behavior: 'smooth' });
      }

      prev.addEventListener('click', () => scrollByOne(-1));
      next.addEventListener('click', () => scrollByOne(1));
      track.addEventListener('scroll', updateButtons, { passive: true });
      window.addEventListener('resize', updateButtons);

      // תמיכה בגרירה בעכבר/אצבע (אופציונלי אך נעים)
      let isDown = false, startX = 0, startLeft = 0;
      track.addEventListener('pointerdown', (e) => {
        isDown = true; startX = e.clientX; startLeft = track.scrollLeft; track.setPointerCapture(e.pointerId);
      });
      track.addEventListener('pointermove', (e) => {
        if (!isDown) return;
        track.scrollLeft = startLeft - (e.clientX - startX);
      });
      track.addEventListener('pointerup', () => { isDown = false; });

      updateButtons();
    })();
</script>
