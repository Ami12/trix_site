        </div>
    </div>
    <p class="subtitle">23 תלמידים מהחלשים בכיתה ג׳ חוו הצלחה אמיתית — והתחילו להאמין בעצמם.</p>
</section>

<!-- עדויות הורים -->
<section class="features fade-in" style="background:#fff;">
    <div class="container">
