@{
    ViewData["Title"] = "הרשמה למשפחות";
}

<section class="hero">
    <div class="hero-inner">
        <div class="hero-top">
            <div class="hero-text">
                <h1>זה לא עוד ציון.<br><span class="accent">זו זהות.</span></h1>
                <p class="trust-line">הילד שלכם קיבל המלצה עלינו ממורה שסומכים עליו. זה כבר אומר הרבה.</p>
                <p>12trix היא סביבת לימוד עצמאית לחשבון, לכיתות א׳-ו׳, שבנויה כולה על התנסות – בלי הסברים ארוכים, בלי טקסט מייגע. הילד לומד דרך משחק, תנועה וגילוי, בקצב שלו.</p>
                <p><strong>מה שאנחנו יודעים בטוח:</strong> ילדים שמתקשים בחשבון לא צריכים עוד הסבר. הם צריכים חוויה שבה הם מצליחים – ומרגישים את זה.</p>
            </div>
            <div class="hero-image">
                <img src="~/img/classRoom.webp" alt="ילדים לומדים חשבון בצורה חווייתית" />
            </div>
        </div>
    </div>

    <div class="trial-wrap">
        <div class="trial-box">
            <div class="gift-label">🎁 שבוע ראשון – במתנה</div>
            <p>כדי שתראו את זה בעצמכם: השבוע הראשון פתוח לכולם, ללא עלות.</p>
            <a href="https://app.12trix.com/Accounts/Account/registerFamily" class="btn-primary">התחילו שבוע ניסיון חינם</a>
            <span class="btn-note">בלי כרטיס אשראי. בלי התחייבות.</span>
        </div>
    </div>
</section>

<section class="next-section">
    <div class="next-inner">
        <img src="~/img/Desktop-1-4-Photoroom.webp" alt="ילד לומד ומצליח בחשבון" />
        <div>
            <h2>מה יקרה אחרי ההרשמה?</h2>
            <p>תוך דקות הילד כבר בתוך הסביבה שלו – בלי צורך לדעת לקרוא, הכול מדובב ומוסבר בקול. ואתם, כהורים, תקבלו גישה לדשבורד שמראה בדיוק איך הוא מתקדם.</p>
        </div>
    </div>
</section>

<section class="video-section">
    <div class="video-inner">
        <h2>לראות את זה במו עיניכם</h2>
        <div class="video-frame">
            <iframe src="https://www.youtube.com/embed/dTUm6IiaORU"
                    title="12trix - ילד לומד חשבון"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen></iframe>
        </div>
    </div>
</section>

<section class="final-cta">
    <div class="final-inner">
        <h2>מוכנים להתחיל?</h2>
        <a href="https://app.12trix.com/Accounts/Account/registerFamily" class="btn-primary">התחילו עכשיו</a>
    </div>
</section>
